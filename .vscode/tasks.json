{
    "tasks": [
        {
            "label": "创建build目录",
            "type": "shell",
            "command": "mkdir",
            "args": [
                "-p",
                "${workspaceFolder}/build"
            ],
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "mac环境编译当前c文件而不是构建项目同时编译多个源文件至一个可执行文件",
            "command": "/usr/bin/clang",
            "args": [
                "-std=c17",
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}/build/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task gererated by chatGPT. -g在可执行文件中加入调试信息/与launch.json配合使用"
        }
    ],
    "version": "2.0.0"
}